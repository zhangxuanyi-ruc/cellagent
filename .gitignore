.ruff_cache/

# Notebook/runtime caches
.ipynb_checkpoints/
*.nbconvert.ipynb

# Local environments
.venv/
venv/
env/
.build-venv/

# Build / packaging artifacts (PyInstaller / wheels)
build/
dist/
release/
*.egg-info/
*.spec

# macOS metadata
.DS_Store

# Nested git repos inside vendored subprojects
src/llm/llm_client/
src/llm/llm_client/.git/
src/llm/llm_client/.build-venv/
src/llm/llm_client/__pycache__/
src/llm/llm_client/build/
src/llm/llm_client/dist/
src/llm/llm_client/release/
src/llm/llm_client/logs/

# Runtime outputs and local data
data/raw/
data/processed/
output/
cellagent_output/
tmp/

# Large model/checkpoint artifacts
*.pt
*.pth
*.ckpt
*.safetensors
*.bin

# Single-cell data artifacts
*.h5ad
*.loom
*.zarr/

# Logs
*.log
*.pid

# External reference repositories are documentation-only locally; avoid broken gitlinks.
reference/**/code/

# Large local knowledge assets. Keep locally or distribute separately.
rag/mappers/
rag/cache/*.parquet
project_plan/*.docx
reference/**/*.pdf
reference/**/*.png
reference/*.png
# Auto-ignore large files (>5MB) added as individual entries

